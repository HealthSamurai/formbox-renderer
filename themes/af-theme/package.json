{
  "name": "@formbox/af-theme",
  "version": "0.3.1",
  "description": "Aidbox Forms Theme for Formbox Renderer",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HealthSamurai/formbox-renderer"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "style": "./dist/index.css"
    },
    "./style.css": {
      "import": "./dist/index.css"
    }
  },
  "style": "./dist/index.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b ./tsconfig.lib.json && vite build",
    "dev": "echo \"@formbox/af-theme: no dev server defined\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "echo \"@formbox/af-theme: no tests defined\""
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "3.4.10",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@formbox/theme": "workspace:*",
    "classnames": "^2.5.1",
    "perfect-freehand": "^1.2.3"
  }
}
