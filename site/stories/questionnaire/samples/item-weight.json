{
  "resourceType": "Questionnaire",
  "id": "item-weight-phq9-demo",
  "status": "active",
  "title": "Item Weight scoring demo",
  "description": "Demonstrates weighted answer options, a minimum answered warning constraint, and calculated total score.",
  "item": [
    {
      "linkId": "phq9",
      "type": "group",
      "text": "Over the last 2 weeks, how often have you been bothered by any of the following problems?",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/targetConstraint",
          "extension": [
            {
              "url": "key",
              "valueId": "constraint-answered-min-3"
            },
            {
              "url": "requirements",
              "valueMarkdown": "At least three questions must be answered to have a meaningful total."
            },
            {
              "url": "severity",
              "valueCode": "warning"
            },
            {
              "url": "expression",
              "valueExpression": {
                "language": "text/fhirpath",
                "expression": "%context.item.where(linkId='q1' or linkId='q2' or linkId='q3' or linkId='q4').where(answer.exists()).count() >= 3"
              }
            },
            {
              "url": "human",
              "valueString": "You should answer at least three questions."
            }
          ]
        },
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-variable",
          "valueExpression": {
            "name": "phq9Score",
            "language": "text/fhirpath",
            "expression": "%context.item.where(linkId='q1' or linkId='q2' or linkId='q3' or linkId='q4').answer.value.weight().aggregate($this + $total, 0)"
          }
        }
      ],
      "item": [
