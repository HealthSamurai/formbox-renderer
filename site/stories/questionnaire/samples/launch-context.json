    {
      "linkId": "patient-id",
      "type": "string",
      "text": "Patient ID",
      "readOnly": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "language": "text/fhirpath",
            "expression": "%patient.id"
          }
        }
      ]
    },
    {
      "linkId": "patient-given-name",
      "type": "string",
      "text": "Patient given name",
      "readOnly": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "language": "text/fhirpath",
            "expression": "%patient.name.given.first().first()"
          }
        }
      ]
    },
    {
      "linkId": "encounter-id",
      "type": "string",
      "text": "Encounter ID",
      "readOnly": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
