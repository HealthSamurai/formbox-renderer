{
  "name": "@formbox/strings",
  "version": "0.1.0",
  "description": "Localized UI strings for Formbox Renderer",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HealthSamurai/formbox-renderer"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./de": {
      "import": "./dist/de.js",
      "types": "./dist/de.d.ts"
    },
    "./en": {
      "import": "./dist/en.js",
      "types": "./dist/en.d.ts"
    },
    "./es": {
      "import": "./dist/es.js",
      "types": "./dist/es.d.ts"
    },
    "./fr": {
      "import": "./dist/fr.js",
      "types": "./dist/fr.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "echo \"@formbox/strings: no dev server defined\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.lib.json",
    "test": "echo \"@formbox/strings: no tests defined\""
  },
  "dependencies": {
    "@formbox/theme": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
